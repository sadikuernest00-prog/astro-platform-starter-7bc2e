---
const title = "AmicBridge";
---

<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{title} – Trust Network</title>

<style>

body{
font-family: Arial, sans-serif;
background:#f3f4f6;
margin:0;
padding:40px;
}

.container{
max-width:900px;
margin:auto;
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 10px 25px rgba(0,0,0,0.05);
}

h1{
margin-bottom:10px;
}

button{
padding:10px 16px;
border:none;
background:#1d4ed8;
color:white;
border-radius:6px;
cursor:pointer;
margin-top:10px;
}

input{
padding:10px;
margin:6px 0;
width:100%;
border:1px solid #ccc;
border-radius:6px;
}

.section{
margin-top:40px;
}

.log{
margin-top:20px;
background:#f9fafb;
padding:15px;
border-radius:8px;
font-family:monospace;
}

</style>

</head>

<body>

<div class="container">

<h1>AmicBridge</h1>

<p>
A peer-to-peer trust credit network where users create trust lines and send value through connections.
</p>

<div class="section">

<h2>Create User</h2>

<input id="username" placeholder="Enter name"/>

<button onclick="createUser()">
Create User
</button>

</div>

<div class="section">

<h2>Add Trust</h2>

<input id="fromUser" placeholder="From user ID"/>
<input id="toUser" placeholder="To user ID"/>
<input id="limit" placeholder="Credit limit"/>

<button onclick="addTrust()">
Add Trust Line
</button>

</div>

<div class="section">

<h2>Send Payment</h2>

<input id="payer" placeholder="From user ID"/>
<input id="receiver" placeholder="To user ID"/>
<input id="amount" placeholder="Amount"/>

<button onclick="sendPayment()">
Send Payment
</button>

</div>

<div class="log" id="log">
System ready
</div>

</div>

<script>

const API = "http://localhost:3000"

function log(msg){
document.getElementById("log").innerText =
JSON.stringify(msg,null,2)
}

async function createUser(){

let name = document.getElementById("username").value

let r = await fetch(API+"/users/create",{
method:"POST",
headers:{'Content-Type':'application/json'},
body:JSON.stringify({name})
})

let data = await r.json()

log(data)

}

async function addTrust(){

let from = document.getElementById("fromUser").value
let to = document.getElementById("toUser").value
let limit = document.getElementById("limit").value

let r = await fetch(API+"/trust/add",{
method:"POST",
headers:{'Content-Type':'application/json'},
body:JSON.stringify({from,to,limit})
})

let data = await r.json()

log(data)

}

async function sendPayment(){

let from = document.getElementById("payer").value
let to = document.getElementById("receiver").value
let amount = document.getElementById("amount").value

let r = await fetch(API+"/payments/send",{
method:"POST",
headers:{'Content-Type':'application/json'},
body:JSON.stringify({from,to,amount})
})

let data = await r.json()

log(data)

}

</script>

</body>
</html>
